# ===== Application =====
# Cổng chạy Service API
PORT=8001
# Môi trường chạy backend: development | staging | production
# production => cookie SameSite=None; Secure
# khác => SameSite=Lax; Secure=false
NODE_ENV=development
# Mức log pino: trace|debug|info|warn|error|fatal (mặc định info)
LOG_LEVEL=info

# ===== Database (PostgreSQL) =====
# Bắt buộc - không có fallback trong code
DB_HOST=localhost
# Tùy chọn - default 5432 trong code nếu để trống.
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=joytab
DB_PARAMS=

# ===== Redis =====
# Bắt buộc - không có fallback trong code
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Google OAuth 2.0 =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== JWT Secret =====
# Secret HS256 ký access token trả về ở POST /auth/google/exchange.
# Google change token và refresh token KHÔNG dùng JWT — sinh ngẫu nhiên + SHA-256 hash lưu Redis.
JWT_SECRET=

# ===== Tích hợp FE-BE =====
# Origin FE để BE redirect (sau login) và làm allowlist fallback nếu thiếu CORS_ALLOWED_ORIGINS.
FRONTEND_ORIGIN=http://localhost:3000
API_URL=http://localhost:8000

# ===== SSO cross-subdomain (web only) =====
# Cookie session_id + device_id dùng chung cho domain cha + mọi subdomain.
# Set domain cha có dấu chấm đầu để chia sẻ cookie: .example.com
# Để TRỐNG ở dev localhost (cookie host-only). KHÔNG dùng được với __Host- prefix.
COOKIE_DOMAIN=

# Allowlist origin cho CORS + CSRF (Origin/Referer check), phân tách bằng dấu phẩy.
# Hỗ trợ exact (https://app.example.com) và wildcard subdomain (https://*.example.com).
# Thiếu biến này thì fallback về FRONTEND_ORIGIN (single-origin).
#   Prod ví dụ: https://*.example.com
#   Dev đa subdomain: dùng *.localtest.me hoặc *.lvh.me (đều trỏ 127.0.0.1, không cần sửa hosts),
#     vd: http://*.localtest.me:3000  — rồi truy cập app.localtest.me:3000, admin.localtest.me:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
