# Cổng public của gateway (FE đang gọi sẵn :8000)
PORT=8000
# URL nội bộ của core service
CORE_URL=http://localhost:8001
# Redis (đọc session để validate) — trùng cấu hình core
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Allowlist origin cho CORS + CSRF (phân tách dấu phẩy; hỗ trợ https://*.example.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development
