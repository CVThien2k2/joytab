# ===== Application =====
# Cổng chạy Service API
PORT=3000
# Môi trường chạy backend: development | staging | production
# production => cookie SameSite=None; Secure
# khác => SameSite=Lax; Secure=false
NODE_ENV=development

# ===== Database (PostgreSQL) =====
# Bắt buộc - không có fallback trong code
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=joytab

# ===== Redis =====
# Bắt buộc - không có fallback trong code
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Google OAuth 2.0 =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ===== JWT Secret =====
# Secret HS256 ký access token trả về ở POST /auth/google/exchange.
# Google change token và refresh token KHÔNG dùng JWT — sinh ngẫu nhiên + SHA-256 hash lưu Redis.
JWT_SECRET=

# ===== Tích hợp FE-BE =====
# Origin FE để BE redirect và cấu hình CORS credentials: true
FRONTEND_ORIGIN=http://localhost:3000
