# Chú thích: [bắt buộc] = nằm trong REQUIRED_ENV_KEYS (app.module.ts), thiếu là app ném lỗi
# khi bootstrap. [tùy chọn] = có default trong code hoặc chỉ dùng khi cần.

# ===== Application =====
# [tùy chọn] Cổng chạy Service API. Default 3000 trong code (main.ts).
PORT=3000
# [tùy chọn] Môi trường backend: development | staging | production
# production => cookie SameSite=None; Secure. Khác => SameSite=Lax; Secure=false.
NODE_ENV=development

# ===== Database (PostgreSQL) =====
# [bắt buộc] DB_HOST, DB_USER, DB_PASSWORD, DB_NAME (database.service.ts + validate ở app.module).
DB_HOST=localhost
# [tùy chọn] Default 5432 khi để trống (prisma.config.ts).
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=joytab
# [tùy chọn] Query params nối vào connection string, vd: sslmode=require
DB_PARAMS=

# ===== Redis =====
# [bắt buộc] REDIS_HOST, REDIS_PORT, REDIS_DB (redis-cache.module.ts + validate). Không có fallback.
REDIS_HOST=localhost
REDIS_PORT=6379
# [tùy chọn] Chỉ set nếu Redis bật auth.
REDIS_PASSWORD=
REDIS_DB=0

# ===== Google OAuth 2.0 =====
# [bắt buộc] GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET (google.strategy.ts).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== JWT Secret =====
# [chưa dùng] Dự kiến là secret HS256 ký access token ở POST /auth/google/exchange,
# nhưng hiện chưa có code nào import jsonwebtoken để đọc biến này (design intent).
# Google change token và refresh token KHÔNG dùng JWT — sinh ngẫu nhiên + SHA-256 hash lưu Redis.
JWT_SECRET=

# ===== Tích hợp FE-BE =====
# [tùy chọn] Origin FE để BE redirect và cấu hình CORS credentials: true. Default http://localhost:3000 (main.ts).
FRONTEND_ORIGIN=http://localhost:3000
# [bắt buộc] Base URL của API, dùng dựng callback Google: ${API_URL}/auth/google/callback (google.strategy.ts).
API_URL=http://localhost:8000
# [tùy chọn] Domain cookie first-party để chia sẻ session giữa FE + API subdomain,
# vd .joytab.com. Để trống ở local (auth.controller.ts). Không set => cookie host-only.
COOKIE_DOMAIN=

