# Base URL API cho FE gọi.
# Phải bao gồm prefix /api/v1: gateway :8000 nhận /api → strip → core /v1/*.
# FE gọi các path tương đối như /auth/me, /auth/switch... => full = <base>/auth/me
# Prod: đổi thành domain gateway thật, vd https://api.joytab.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
